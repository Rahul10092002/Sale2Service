<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice <%= invoice.number %></title>
    <style>
        @page {
            margin: 0;
            size: A4;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            font-size: 10px;
            line-height: 1.4;
            color: #1f2937;
            padding: 12mm;
            background: #fff;
        }
        
        .invoice-card {
            background: #fff;
        }

        .header-main {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .brand-section {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }
        
        .logo-placeholder {
            width: 50px;
            height: 50px;
            background: #f3f4f6;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-top: 2px;
        }

        .logo-placeholder img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
        
        .shop-info h1 {
            font-size: 16px;
            font-weight: 800;
            color: #111827;
            letter-spacing: -0.025em;
            margin-bottom: 1px;
        }

        .shop-meta {
            font-size: 9px;
            color: #6b7280;
            line-height: 1.3;
        }
        
        .invoice-label {
            text-align: right;
        }

        .invoice-label h2 {
            font-size: 22px;
            font-weight: 900;
            color: #2563eb;
            letter-spacing: -0.05em;
            margin-bottom: 2px;
        }

        .invoice-number {
            font-size: 12px;
            font-weight: 600;
            color: #374151;
        }

        .details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 25px;
        }

        .section-title {
            font-size: 8px;
            text-transform: uppercase;
            font-weight: 700;
            color: #6b7280;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 3px;
        }

        .info-block p {
            margin-bottom: 1px;
        }

        .info-block strong {
            color: #111827;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .items-table th {
            background: #f9fafb;
            text-align: left;
            padding: 8px 10px;
            font-size: 8px;
            font-weight: 700;
            text-transform: uppercase;
            color: #4b5563;
            border-bottom: 1.5px solid #e5e7eb;
        }

        .items-table td {
            padding: 8px 10px;
            border-bottom: 1px solid #f3f4f6;
            vertical-align: top;
        }

        .item-main {
            font-weight: 600;
            color: #111827;
            margin-bottom: 2px;
        }

        .item-sub {
            font-size: 8px;
            color: #6b7280;
        }

        .summary-section {
            display: flex;
            justify-content: space-between;
            margin-top: 15px;
        }

        .payment-info {
            flex: 1;
            max-width: 380px;
        }

        .bank-details {
            background: #f8fafc;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #e2e8f0;
            margin-top: 6px;
            display: flex;
            gap: 15px;
            align-items: flex-start;
        }

        .bank-text {
            flex: 1;
        }

        .bank-details h4 {
            font-size: 9px;
            margin-bottom: 5px;
            color: #334155;
            font-weight: 700;
            text-transform: uppercase;
        }

        .qr-code {
            width: 75px;
            height: 75px;
            background: #fff;
            padding: 4px;
            border-radius: 4px;
            border: 1px solid #e2e8f0;
        }

        .qr-code img {
            width: 100%;
            height: 100%;
        }

        .totals-block {
            width: 200px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 4px 0;
            font-size: 10px;
        }

        .total-row.grand-total {
            margin-top: 8px;
            padding: 10px;
            background: #2563eb;
            color: #fff;
            border-radius: 6px;
            font-weight: 700;
            font-size: 12px;
        }

        .status-badge {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 9999px;
            font-size: 7px;
            font-weight: 700;
            text-transform: uppercase;
            margin-top: 3px;
        }

        .status-paid { background: #dcfce7; color: #166534; }
        .status-pending { background: #fef9c3; color: #854d0e; }
        .status-unpaid { background: #fee2e2; color: #991b1b; }

        .footer {
            margin-top: 60px;
            text-align: center;
            color: #9ca3af;
            font-size: 9px;
            border-top: 1px solid #f3f4f6;
            padding-top: 20px;
        }
    </style>
</head>
<body>
    <div class="invoice-card">
        <!-- Header -->
        <div class="header-main">
            <div class="brand-section">
                <% if (shop.logo_url) { %>
                <div class="logo-placeholder">
                    <img src="<%= shop.logo_url %>" alt="Logo" />
                </div>
                <% } %>
                <div class="shop-info">
                    <h1><%= shop.name %></h1>
                    <div class="shop-meta">
                        <% if (shop.gstNumber) { %>GSTIN: <%= shop.gstNumber %><br><% } %>
                        <%= shop.address.street || '' %><br>
                        <%= [shop.address.city, shop.address.state, shop.address.pincode].filter(Boolean).join(', ') %>
                    </div>
                </div>
            </div>
            <div class="invoice-label">
                <h2>INVOICE</h2>
                <div class="invoice-number">#<%= invoice.number %></div>
                <div class="status-badge status-<%= (invoice.payment_status || 'UNPAID').toLowerCase() %>">
                    <%= invoice.payment_status || 'UNPAID' %>
                </div>
            </div>
        </div>

        <!-- Details -->
        <div class="details-grid">
            <div class="info-block">
                <div class="section-title">Billed To</div>
                <p><strong><%= customer.name %></strong></p>
                <% if (customer.address && (customer.address.street || customer.address.city)) { %>
                <p class="shop-meta">
                    <%= customer.address.street || '' %><br>
                    <%= [customer.address.city, customer.address.state, customer.address.pincode].filter(Boolean).join(', ') %>
                </p>
                <% } %>
                <% if (customer.mobile) { %><p class="shop-meta">Mob: <%= customer.mobile %></p><% } %>
                <% if (customer.gstNumber) { %><p class="shop-meta">GSTIN: <%= customer.gstNumber %></p><% } %>
            </div>
            <div class="info-block">
                <div class="section-title">Invoice Details</div>
                <div class="total-row">
                    <span class="shop-meta">Date:</span>
                    <span style="font-weight: 600;"><%= invoice.date %></span>
                </div>
                <% if (invoice.dueDate) { %>
                <div class="total-row">
                    <span class="shop-meta">Due Date:</span>
                    <span style="font-weight: 600;"><%= invoice.dueDate %></span>
                </div>
                <% } %>
                <div class="total-row">
                    <span class="shop-meta">Method:</span>
                    <span style="font-weight: 600;"><%= invoice.paymentMode %></span>
                </div>
            </div>
        </div>

        <!-- Items -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 40px;">#</th>
                    <th>Description</th>
                    <th style="text-align: center;">Qty</th>
                    <th style="text-align: right;">Rate</th>
                    <th style="text-align: right;">Tax</th>
                    <th style="text-align: right;">Amount</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item, i) { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td>
                        <div class="item-main"><%= item.productName %></div>
                        <% if (item.modelNumber && item.modelNumber !== 'N/A') { %>
                            <span class="item-sub">Model: <%= item.modelNumber %></span>
                        <% } %>
                        <% if (item.serialNumber && item.serialNumber !== 'N/A') { %>
                            <span class="item-sub"> | S/N: <%= item.serialNumber %></span>
                        <% } %>
                        <% if (item.batteryLine) { %>
                            <div class="item-sub"><%= item.batteryLine %></div>
                        <% } %>
                    </td>
                    <td style="text-align: center;"><%= item.quantity %></td>
                    <td style="text-align: right;"><%= item.unitPrice %></td>
                    <td style="text-align: right;"><%= item.taxAmount %></td>
                    <td style="text-align: right; font-weight: 600;"><%= item.amount %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Summary -->
        <div class="summary-section">
            <div class="payment-info">
                <% if (shop.bank_details && (shop.bank_details.bank_name || shop.bank_details.upi_id)) { %>
                <div class="section-title">Payment Details</div>
                <div class="bank-details" style="background: transparent; border: none; padding: 0;">
                    <% if (upiQRCode) { %>
                    <div class="qr-wrapper" style="text-align: left;">
                        <div class="qr-code">
                            <img src="<%= upiQRCode %>" alt="Payment QR" />
                        </div>
                        <div style="font-size: 7px; color: #94a3b8; font-weight: 600; margin-top: 4px; text-align: center;">SCAN TO PAY</div>
                    </div>
                    <% } %>
                </div>
                <% } %>
                
                <% if (invoice.notes) { %>
                <div style="margin-top: 20px;">
                    <div class="section-title">Notes</div>
                    <p class="shop-meta"><%= invoice.notes %></p>
                </div>
                <% } %>
            </div>

            <div class="totals-block">
                <div class="total-row">
                    <span class="shop-meta">Subtotal</span>
                    <span><%= totals.subtotal %></span>
                </div>
                <% if (totals.discountRaw > 0) { %>
                <div class="total-row">
                    <span class="shop-meta">Discount</span>
                    <span style="color: #dc2626;">-<%= totals.discount %></span>
                </div>
                <% } %>
                <div class="total-row">
                    <span class="shop-meta">Tax (<%= totals.gstRate %>%)</span>
                    <span><%= totals.gstAmount %></span>
                </div>
                
                <div class="total-row grand-total">
                    <span>Total Amount</span>
                    <span><%= totals.total %></span>
                </div>

                <% if (payment.amountPaidRaw > 0) { %>
                <div class="total-row" style="padding-top: 10px; border-top: 1px solid #f3f4f6; margin-top: 10px;">
                    <span class="shop-meta">Amount Paid</span>
                    <span style="color: #059669; font-weight: 600;"><%= payment.amount_paid %></span>
                </div>
                <% } %>
                <% if (payment.amountDueRaw > 0) { %>
                <div class="total-row">
                    <span class="shop-meta">Balance Due</span>
                    <span style="color: #dc2626; font-weight: 700;"><%= payment.amount_due %></span>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <p>Thank you for your business! This is a computer-generated invoice.</p>
            <p>Generated on <%= generatedOn %> • Page 1 of 1</p>
        </div>
    </div>
</body>
</html>
