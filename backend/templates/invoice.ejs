<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice <%= invoice.number %></title>
    <style>
        @page {
            margin: 0;
            size: A4;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', sans-serif;
            font-size: 12px;
            line-height: 1.6;
            color: #333;
            padding: 15mm;
        }
        
        .invoice-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 20px;
        }
        
        .company-logo {
            flex: 0 0 80px;
            margin-right: 20px;
        }
        
        .company-logo img {
            max-width: 80px;
            max-height: 80px;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        .company-details {
            flex: 1;
        }
        
        .company-name {
            font-size: 24px;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 5px;
        }
        
        .company-address {
            font-size: 11px;
            color: #666;
            line-height: 1.4;
        }
        
        .invoice-title {
            text-align: right;
            flex: 0 0 200px;
        }
        
        .invoice-title h1 {
            font-size: 28px;
            color: #e74c3c;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .invoice-meta {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }
        
        .invoice-info, .customer-info {
            flex: 1;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 5px;
            margin: 0 10px;
        }
        
        .invoice-info h3, .customer-info h3 {
            color: #2c3e50;
            border-bottom: 2px solid #3498db;
            padding-bottom: 5px;
            margin-bottom: 10px;
            font-size: 14px;
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
        
        .info-label {
            font-weight: bold;
            color: #555;
        }
        
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            border: 1px solid #ddd;
        }
        
        .items-table th {
            background: #34495e;
            color: white;
            padding: 12px 8px;
            text-align: left;
            font-size: 11px;
            font-weight: bold;
        }
        
        .items-table td {
            padding: 10px 8px;
            border-bottom: 1px solid #eee;
            font-size: 11px;
        }
        
        .items-table tbody tr:nth-child(even) {
            background: #f8f9fa;
        }
        
        .text-right {
            text-align: right;
        }
        
        .text-center {
            text-align: center;
        }
        
        .totals-section {
            margin-top: 30px;
            float: right;
            width: 300px;
        }
        
        .totals-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .totals-table td {
            padding: 8px 15px;
            border: 1px solid #ddd;
        }
        
        .totals-table .label {
            font-weight: bold;
            background: #f8f9fa;
            text-align: right;
        }
        
        .totals-table .total-row {
            background: #2c3e50;
            color: white;
            font-weight: bold;
            font-size: 14px;
        }
        
        .footer {
            clear: both;
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
            font-size: 10px;
            color: #666;
            text-align: center;
        }
        
        .notes-section {
            clear: both;
            margin-top: 30px;
            padding: 15px;
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 5px;
        }
        
        .notes-section h4 {
            color: #856404;
            margin-bottom: 10px;
        }
        
        .status-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 3px;
            font-size: 10px;
            font-weight: bold;
            text-transform: uppercase;
        }
        
        .status-paid {
            background: #d4edda;
            color: #155724;
        }
        
        .status-pending {
            background: #fff3cd;
            color: #856404;
        }

        .status-unpaid {
            background: #fff3cd;
            color: #856404;
        }

        .status-partial {
            background: #fff4e5;
            color: #b45309;
        }
        
        .status-overdue {
            background: #f8d7da;
            color: #721c24;
        }
    </style>
</head>
<body>
    <!-- Header Section -->
    <div class="invoice-header">
        <% if (shop.logo_url) { %>
        <div class="company-logo">
            <img src="<%= shop.logo_url %>" alt="<%= shop.name %> Logo" />
        </div>
        <% } %>
        <div class="company-details">
            <div class="company-name"><%= shop.name ? (shop.name.charAt(0).toUpperCase() + shop.name.slice(1)) : '' %></div>
            <div class="company-address">
                <% if (shop.business_type) { %><div><strong><%= shop.business_type %></strong></div><% } %>
                <% if (shop.ownerName) { %>Owner: <%= shop.ownerName %><br><% } %>
                <% if (shop.address && (shop.address.street || shop.address.city || shop.address.state || shop.address.pincode)) { %>
                    <% if (shop.address.street) { %><%= shop.address.street %><br><% } %>
                    <%= [shop.address.city, shop.address.state, shop.address.pincode].filter(Boolean).join(', ') %><br>
                <% } %>
                <% if (shop.mobile) { %>Phone: <%= shop.mobile %><br><% } %>
                <% if (shop.email) { %>Email: <%= shop.email %><br><% } %>
                <% if (shop.gstNumber) { %>GST: <%= shop.gstNumber %><% } %>
            </div>
        </div>
        <div class="invoice-title">
            <h1>INVOICE</h1>
        </div>
    </div>

    <!-- Invoice & Customer Info -->
    <div class="invoice-meta">
        <div class="invoice-info">
            <h3>Invoice Details</h3>
            <div class="info-row">
                <span class="info-label">Invoice #:</span>
                <span><%= invoice.number %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Invoice Date:</span>
                <span><%= invoice.date %></span>
            </div>
            <% if (invoice.dueDate) { %>
            <div class="info-row">
                <span class="info-label">Due Date:</span>
                <span style="<%= ['UNPAID', 'PARTIAL'].includes(invoice.payment_status) ? 'color: #e74c3c; font-weight: bold;' : '' %>"><%= invoice.dueDate %></span>
            </div>
            <% } %>
            <div class="info-row">
                <span class="info-label">Status:</span>
                <span class="status-badge status-<%= invoice.isOverdue ? 'overdue' : (invoice.payment_status || 'UNPAID').toLowerCase() %>">
                    <%= invoice.payment_status || 'UNPAID' %>
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">Payment Mode:</span>
                <span><%= invoice.paymentMode %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Due State:</span>
                <span style="<%= invoice.isOverdue ? 'color: #e74c3c; font-weight: bold;' : '' %>"><%= invoice.dueState %></span>
            </div>
        </div>

        <div class="customer-info">
            <h3>Bill To</h3>
            <div class="info-row">
                <span class="info-label">Name:</span>
                <span><%= customer.name %></span>
            </div>
            <% if (customer.email) { %>
            <div class="info-row">
                <span class="info-label">Email:</span>
                <span><%= customer.email %></span>
            </div>
            <% } %>
            <% if (customer.mobile) { %>
            <div class="info-row">
                <span class="info-label">Mobile:</span>
                <span><%= customer.mobile %></span>
            </div>
            <% } %>
            <% if (customer.address && (customer.address.street || customer.address.city)) { %>
            <div class="info-row">
                <span class="info-label">Address:</span>
                <span>
                    <% if (customer.address.street) { %><%= customer.address.street %><br><% } %>
                    <%= [customer.address.city, customer.address.state, customer.address.pincode].filter(Boolean).join(', ') %>
                </span>
            </div>
            <% } %>
            <% if (customer.gstNumber) { %>
            <div class="info-row">
                <span class="info-label">GST:</span>
                <span><%= customer.gstNumber %></span>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Items Table -->
    <table class="items-table">
        <thead>
            <tr>
                <th style="width: 5%;">S.No</th>
                <th style="width: 25%;">Product Name</th>
                <th style="width: 15%;">Model</th>
                <th style="width: 15%;">Serial No.</th>
                <th style="width: 8%;">Qty</th>
                <th style="width: 12%;">Unit Price</th>
                <th style="width: 12%;">Amount</th>
                <th style="width: 8%;">Warranty</th>
            </tr>
        </thead>
        <tbody>
            <% items.forEach(function(item) { %>
            <tr>
                <td class="text-center"><%= item.sno %></td>
                <td>
                    <%= item.productName %>
                    <% if (item.batteryLine) { %>
                        <br><small style="color: #555; font-size: 10px;"><%= item.batteryLine %></small>
                    <% } %>
                    <% if (item.hasServicePlan) { %>
                        <br><small style="color: #27ae60; font-weight: bold;">✓ Service Plan Included</small>
                    <% } %>
                </td>
                <td><%= item.modelNumber || '-' %></td>
                <td><%= item.serialNumber || '-' %></td>
                <td class="text-center"><%= item.quantity %></td>
                <td class="text-right"><%= item.unitPrice %></td>
                <td class="text-right"><%= item.amount %></td>
                <td class="text-center"><%= item.warrantyPeriod %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <!-- Totals Section -->
    <div class="totals-section">
        <table class="totals-table">
            <tr>
                <td class="label">Subtotal:</td>
                <td class="text-right"><%= totals.subtotal %></td>
            </tr>
            <% if (totals.discountRaw > 0) { %>
            <tr>
                <td class="label">Discount:</td>
                <td class="text-right" style="color: #c0392b;">-<%= totals.discount %></td>
            </tr>
            <% } %>
            <tr>
                <td class="label">GST (<%= totals.gstRate %>%):</td>
                <td class="text-right"><%= totals.gstAmount %></td>
            </tr>
            <tr class="total-row">
                <td class="label">Total Amount:</td>
                <td class="text-right"><%= totals.total %></td>
            </tr>
            <% if (typeof payment !== 'undefined' && payment && ['UNPAID', 'PARTIAL'].includes(invoice.payment_status)) { %>
                <% if (payment.amount_paid && payment.amount_paid !== '₹0.00') { %>
                <tr>
                    <td class="label">Amount Paid:</td>
                    <td class="text-right" style="color: #27ae60;"><%= payment.amount_paid %></td>
                </tr>
                <% } %>
                <% if (payment.amount_due && payment.amount_due !== '₹0.00') { %>
                <tr style="background: #fff5f5;">
                    <td class="label" style="color: #e74c3c; font-weight: bold;">Amount Due:</td>
                    <td class="text-right" style="color: #e74c3c; font-weight: bold;"><%= payment.amount_due %></td>
                </tr>
                <% } %>
            <% } %>
        </table>
    </div>

    <!-- Notes Section -->
    <% if (invoice.notes) { %>
    <div class="notes-section">
        <h4>Notes:</h4>
        <p><%= invoice.notes %></p>
    </div>
    <% } %>

    <!-- Footer -->
    <div class="footer">
        <p>Thank you for your business!</p>
        <p>This invoice was generated on <%= generatedOn %></p>
        <hr style="margin: 10px 0; border: none; border-top: 1px solid #ddd;">
        <p><em>This is a computer generated invoice and does not require signature.</em></p>
    </div>
</body>
</html>
