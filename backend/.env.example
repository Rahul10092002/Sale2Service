# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/warranty_sales_db

# JWT Secret Keys
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
# Generate a strong random key for production using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Application Settings
API_VERSION=v1

# ─── Twilio WhatsApp Configuration ────────────────────────────────────────────
# Get these from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# DEVELOPMENT  → use the Twilio WhatsApp Sandbox number below (no WhatsApp approval needed).
#   Recipients must first send  "join <sandbox-keyword>"  to +14155238886 on WhatsApp.
#   Find your keyword at: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_WHATSAPP_NUMBER=+14155238886

# PRODUCTION   → replace with your WhatsApp Business approved Twilio number.
# TWILIO_WHATSAPP_NUMBER=+1XXXXXXXXXX
